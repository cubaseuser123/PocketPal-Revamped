# API URL for development
# Set this to your backend server URL
# Default fallback in code uses ngrok URL for mobile, localhost for web

# For local development (default):
EXPO_PUBLIC_API_URL=http://localhost:5757

# For Android Emulator (uses 10.0.2.2 to reach host machine):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5757

# For physical devices on the same network:
# EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:5757

# For ngrok tunneling (remote testing):
# EXPO_PUBLIC_API_URL=https://your-subdomain.ngrok-free.dev
