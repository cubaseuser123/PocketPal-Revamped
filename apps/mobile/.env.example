# API URL for development
# For physical devices on the same network, use your computer's local IP:
# EXPO_PUBLIC_API_URL=http://192.168.X.X:5757
# For iOS Simulator: localhost works
# For Android Emulator: 10.0.2.2 works (handled in code)

# Uncomment and set your local IP for Expo Go on physical devices:
# EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:5757
