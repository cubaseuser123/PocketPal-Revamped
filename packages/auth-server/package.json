    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --ext .ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.41.0",
    "postgres": "^3.4.0",
    "twilio": "^5.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}

